CONFIG_SYS_CLOCK_HW_CYCLES_PER_SEC=125000000

# Enable reset by default
CONFIG_RESET=y
CONFIG_CLOCK_CONTROL=y

# Code partition needed to target the correct flash range
CONFIG_USE_DT_CODE_PARTITION=y

# Output UF2 by default, native bootloader supports it.
CONFIG_BUILD_OUTPUT_UF2=y

CONFIG_ZMK_USB=y
CONFIG_ZMK_MOUSE=y
# May not work well on MacOS
# CONFIG_ZMK_POINTING_SMOOTH_SCROLLING=y

# zmk-input-processor-acceleration (nuovotaka): unlike the predecessor,
# this Kconfig has no `default $(dt_compat_enabled,...)` so the parent symbol
# has to be enabled explicitly. The choice config below depends on the parent.
CONFIG_ZMK_INPUT_PROCESSOR_ACCELERATION=y
# Pick the multi-speed "Standard" curve so the min-factor/max-factor/
# speed-threshold/speed-max/acceleration-exponent properties in
# ploopy_adept.dts take effect. (Default is SIMPLE which uses a different
# property set.)
CONFIG_INPUT_PROCESSOR_ACCEL_LEVEL_STANDARD=y

# zmk-input-processor-scroll-inertia (mjmjm0101) — auto-enables when the
# &scroll_inertia node is referenced, so no explicit CONFIG needed here.

# Required for persistant settings (mouse wheel DPI and studio keymaps)
CONFIG_MPU_ALLOW_FLASH_WRITE=y
CONFIG_NVS=y
CONFIG_SETTINGS_NVS=y
CONFIG_FLASH=y
CONFIG_FLASH_PAGE_LAYOUT=y
CONFIG_FLASH_MAP=y
CONFIG_SETTINGS=y

CONFIG_ZMK_STUDIO=y